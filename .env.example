# ════════════════════════════════════════════════════════════════
#  Tadkira — API Gateway Service  |  .env.example
#
#  1. Copier ce fichier : cp .env.example .env
#  2. Adapter les valeurs si besoin
#  3. Démarrer l'infra d'abord : cd ../TADKIRA-INFRA && docker-compose -f docker-compose.infra.yml up -d
#  4. Lancer le service      : docker-compose up -d
# ════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── JWT ──────────────────────────────────────────────────────
# Doit correspondre EXACTEMENT au secret configuré dans l'Auth Service
JWT_SECRET=tadkira-super-secret-jwt-key-dev-only-32chars
JWT_EXPIRATION=24h

# ─── Redis (Rate Limiting) ────────────────────────────────────
# Fourni par l'infra partagée (conteneur 'redis' sur tadkira-network)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── URLs des Microservices ───────────────────────────────────
# Utiliser les noms de conteneurs Docker (réseau tadkira-network)
AUTH_SERVICE_URL=http://auth-service:3001
FLIGHT_SERVICE_URL=http://flight-booking-service:3002
CHECKIN_SERVICE_URL=http://checkin-service:3003
OCR_SERVICE_URL=http://ocr-service:3004
BOARDING_PASS_SERVICE_URL=http://boarding-pass-service:3005

# ─── Rate Limiting Global ────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Swagger ─────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
